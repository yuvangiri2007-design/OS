#include <stdio.h>
#include <sys/ipc.h>
#include <sys/msg.h>
#include <string.h>

struct msgbuf {
    long mtype;
    char mtext[100];
};

int main() {
    struct msgbuf message;
    int msgid;

    msgid = msgget(1234, 0666 | IPC_CREAT);

    message.mtype = 1;
    strcpy(message.mtext, "Hello Message Queue");

    msgsnd(msgid, &message, sizeof(message), 0);

    msgrcv(msgid, &message, sizeof(message), 1, 0);

    printf("Message: %s\n", message.mtext);

    return 0;
}
OUTPUT:
Message: Hello Message Queue
