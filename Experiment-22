#include <stdio.h>

int main()
{
    int block[5]={100,500,200,300,600};
    int process[4]={212,417,112,426};

    for(int i=0;i<4;i++)
    {
        int best=-1;

        for(int j=0;j<5;j++)
        {
            if(block[j]>=process[i])
            {
                if(best==-1 || block[j]<block[best])
                    best=j;
            }
        }

        if(best!=-1)
        {
            printf("Process %d -> Block %d\n",i+1,best+1);
            block[best]-=process[i];
        }
    }
}
OUTPUT:
Process 1 -> Block 4
Process 2 -> Block 2
Process 3 -> Block 3
