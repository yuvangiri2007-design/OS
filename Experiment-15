#include <stdio.h>

int main()
{
    int users,files;

    printf("Enter number of users: ");
    scanf("%d",&users);

    for(int i=0;i<users;i++)
    {
        printf("User %d files count: ",i+1);
        scanf("%d",&files);

        char fname[20];

        for(int j=0;j<files;j++)
        {
            printf("Enter file name: ");
            scanf("%s",fname);
        }
    }

    printf("Two Level Directory Created\n");
    return 0;
}
OUTPUT:
Two Level Directory Created
