#include <stdio.h>
#include <pthread.h>

void *display(void *arg)
{
    printf("Thread is executing\n");
    pthread_exit(NULL);
}

int main()
{
    pthread_t t1;
    pthread_create(&t1, NULL, display, NULL);
    pthread_join(t1, NULL);
    printf("Thread completed\n");
    return 0;
} 
OUTPUT:
Thread is executing
Thread completed
