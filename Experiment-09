#include <stdio.h>
#include <sys/ipc.h>
#include <sys/shm.h>
#include <string.h>

int main() {
    key_t key = 1234;
    int shmid;

    char *str;

    shmid = shmget(key,1024,0666|IPC_CREAT);

    str = (char*)shmat(shmid,NULL,0);

    strcpy(str,"Hello Shared Memory");

    printf("Data Written: %s\n",str);

    shmdt(str);

    return 0;
}
OUTPUT:
Data Written: Hello Shared Memory
