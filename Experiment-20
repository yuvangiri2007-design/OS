#include <stdio.h>
#include <pthread.h>
#include <semaphore.h>

sem_t wrt;
int data=10;

void *reader(void *arg)
{
    printf("Reader reads %d\n",data);
    return NULL;
}

void *writer(void *arg)
{
    sem_wait(&wrt);
    data++;
    printf("Writer updates data to %d\n",data);
    sem_post(&wrt);
    return NULL;
}

int main()
{
    pthread_t r,w;

    sem_init(&wrt,0,1);

    pthread_create(&w,NULL,writer,NULL);
    pthread_create(&r,NULL,reader,NULL);

    pthread_join(w,NULL);
    pthread_join(r,NULL);

    return 0;
}
OUTPUT:
Writer updates data to 11
Reader reads 11
