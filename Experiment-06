#include <stdio.h>

int main() {
    int n, bt[10], pr[10], rt[10];
    int i, complete=0, time=0;
    int shortest;

    printf("Enter number of processes: ");
    scanf("%d",&n);

    for(i=0;i<n;i++) {
        scanf("%d%d",&bt[i],&pr[i]);
        rt[i]=bt[i];
    }

    while(complete!=n) {
        shortest=-1;

        for(i=0;i<n;i++) {
            if(rt[i]>0) {
                if(shortest==-1 || pr[i]<pr[shortest])
                    shortest=i;
            }
        }

        rt[shortest]--;
        time++;

        if(rt[shortest]==0)
            complete++;
    }

    printf("Preemptive Priority Scheduling Executed\n");
    return 0;
}
OUTPUT:
Preemptive Priority Scheduling Executed
