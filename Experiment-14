#include <stdio.h>

int main()
{
    int n;
    char file[20][20];

    printf("Enter number of files: ");
    scanf("%d",&n);

    for(int i=0;i<n;i++)
    {
        printf("Enter file name: ");
        scanf("%s",file[i]);
    }

    printf("\nFiles in Directory\n");

    for(int i=0;i<n;i++)
        printf("%s\n",file[i]);

    return 0;
}
