#include <stdio.h>
#include <fcntl.h>
#include <unistd.h>

int main()
{
    int fd;

    fd=open("sample.txt",O_CREAT|O_RDWR,0644);

    write(fd,"Hello UNIX",10);

    lseek(fd,0,SEEK_SET);

    char buf[20];

    read(fd,buf,10);
    buf[10]='\0';

    printf("%s\n",buf);

    close(fd);

    return 0;
}
